{
	"name": "VSCode R",
	"image": "mattocci/cmdstan-zsh:4.6.0",

  "containerUser": "rstudio",
  "remoteUser": "rstudio",
  "updateRemoteUserUID": false,

	"containerEnv": {
    "HOME": "/home/rstudio",
    "VSCODE_AGENT_FOLDER": "/home/rstudio/.vscode-server",
		"RENV_PATHS_CACHE": "/renv",
		"INSIDE_CONTAINER": "true",
		"INSIDE_DOCKER": "true",
    "TERM_PROGRAM": "vscode",
    "HOST_UID": "${env:HOST_UID}",
    "HOST_GID": "${env:HOST_GID}",
    "http_proxy": "${localEnv:HTTP_PROXY}",
    "https_proxy": "${localEnv:HTTPS_PROXY}",
    "no_proxy": "${localEnv:NO_PROXY}"
	},

  "runArgs": [
    "--network=host",
    "--group-add=20"
  ],

  "mounts": [
    "source=${env:HOME}/renv,target=/renv,type=bind,consistency=cached",
		"source=${env:HOME}/dotfiles/zsh/.zsh/99_secrets.zsh,target=/home/rstudio/.99_secrets.zsh.tmp,type=bind,readonly"
  ],

	"postCreateCommand": "if [ ! -d \"/home/rstudio/dotfiles\" ]; then git clone https://github.com/mattocci27/dotfiles.git /home/rstudio/dotfiles; fi && mkdir -p /home/rstudio/dotfiles/zsh/.zsh && ln -sf /home/rstudio/.99_secrets.zsh.tmp /home/rstudio/dotfiles/zsh/.zsh/99_secrets.zsh && cd /home/rstudio/dotfiles && ./install.sh",

	"customizations": {
		"vscode": {
			"extensions": [
				"reditorsupport.r",
				"quarto.quarto",
				"mhutchie.git-graph",
				"donjayamanne.githistory",
				"rlivings39.fzf-quick-open",
				"openai.codex",
				"anthropic.claude-code"
				],
				"settings": {
  				"http.proxy": "http://host.docker.internal:2080",
    			"http.proxyStrictSSL": false,
					"r.rterm.linux": "/opt/venv/bin/radian",
					"r.rpath.linux": "/usr/local/bin/R",
					"r.sessionWatcher": true,
					"r.plot.useHttpgd": true,
					"quarto.path": "/usr/local/bin/quarto"
				}
		}
	}
}
